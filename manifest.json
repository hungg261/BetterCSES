{
  "manifest_version": 3,
  "name": "CSES Helper",
  "description": "Tools for CSES Online Judge",
  "homepage_url": "https://github.com/hungg261/BetterCSES",
  "version": "1.0.0",
  "author": "hungg261",
  "action": {
    "default_icon": "assets/favicon.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://cses.fi/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://cses.fi/*"
      ],
      "js": [
        "./scripts/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "./scripts/background.js"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none';"
  }
}
